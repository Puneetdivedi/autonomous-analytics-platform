# ─────────────────────────────────────────────────────────────
# Enterprise Autonomous Analytics Platform — environment template
# Copy to .env and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- App ---
APP_NAME=Enterprise Autonomous Analytics Platform
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Security / JWT ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# --- PostgreSQL (application metadata) ---
POSTGRES_USER=eaap
POSTGRES_PASSWORD=eaap_password
POSTGRES_DB=eaap
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://eaap:eaap_password@postgres:5432/eaap

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant (vector store / long-term memory) ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# --- LLM provider selection ---
# Use `stub` to run the full agent graph with NO API key (deterministic,
# schema-valid canned outputs) — ideal for local demos, CI and tests.
LLM_PROVIDER=openai                # openai | anthropic | gemini | groq | ollama | stub
LLM_MODEL=gpt-4o
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-sonnet-5
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=3

# --- Provider keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- LangFuse observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=true

# --- Agent graph limits ---
MAX_GRAPH_ITERATIONS=25
MAX_SQL_ROWS=10000
AGENT_NODE_TIMEOUT_SECONDS=120

# --- File storage ---
UPLOAD_DIR=/data/uploads
REPORT_DIR=/data/reports
MAX_UPLOAD_MB=100
